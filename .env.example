# Supabase 接続情報
# Supabase ダッシュボード → Settings → API から取得する
VITE_SUPABASE_URL=#
VITE_SUPABASE_ANON_KEY=#

# フロントエンドのベース URL（LINE 返信の申込 URL 生成に使用）
# ローカル開発: http://localhost:5173
# 本番: https://your-domain.vercel.app
VITE_FRONTEND_URL=http://localhost:5173

# LINE 公式アカウントの友だち追加 URL（トップページのボタンリンク）
VITE_LINE_ADD_FRIEND_URL=#

# 問い合わせページ URL（断り確定画面などで表示）
VITE_CONTACT_URL=https://line.me/R/ti/p/your-line-id

# ---- Supabase Edge Function 用シークレット（supabase secrets set で登録する） ----
# LINE Messaging API チャンネルシークレット（署名検証に使用）
# LINE_CHANNEL_SECRET=your-channel-secret
# LINE Messaging API チャンネルアクセストークン（メッセージ送信に使用）
# LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
